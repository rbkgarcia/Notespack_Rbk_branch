@page "/event/edit/{EventId:int}"
@using NOTESPACK.Models
@using NOTESPACK.Services
@using Microsoft.AspNetCore.Components.Authorization
@rendermode InteractiveServer

@inject EventService EventService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation

<div class="edit-event-page">
    <div class="main-container">
        <div class="page-header">
            <h1>Edit Event</h1>
        </div>

        @if (EventModel == null)
        {
            <p>Loading event details...</p>
        }
        else
        {
            <div class="glass-card form-container">
                <EditForm Model="EventModel" OnValidSubmit="HandleSave">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="form-group">
                        <label>Title</label>
                        <InputText @bind-Value="EventModel.Title" class="form-input" />
                    </div>

                    <div class="form-group">
                        <label>Description</label>
                        <InputTextArea @bind-Value="EventModel.Description" class="form-input" />
                    </div>

                    <div class="form-group">
                        <label>Date</label>
                        <InputDate @bind-Value="EventModel.Date" class="form-input" />
                    </div>

                    <div class="form-group">
                        <label>Location</label>
                        <InputText @bind-Value="EventModel.Location" class="form-input" />
                    </div>

                    <div class="form-actions mt-4">
                        <button type="submit" class="btn-submit">Save Changes</button>
                        <NavLink href="my-events" class="btn-cancel">Cancel</NavLink>
                    </div>
                </EditForm>
            </div>
        }
    </div>
</div>

@code 
{
    [Parameter] public int EventId { get; set; }
    private Event? EventModel { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userIdString = authState.User.FindFirst("UserId")?.Value;

        if (int.TryParse(userIdString, out int userId))
        {
            // Cargamos todos los eventos y buscamos el específico por ID
            var events = await EventService.GetEventsByUserIdAsync(userId);
            EventModel = events.FirstOrDefault(e => e.Id == EventId);
            
            if (EventModel == null) 
            {
                // Si el evento no existe o no pertenece al usuario, regresamos a la lista
                Navigation.NavigateTo("/my-events");
            }
        }
        else
        {
            Navigation.NavigateTo("/login");
        }
    }

    private async Task HandleSave()
    {
        if (EventModel == null) return;

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userIdString = authState.User.FindFirst("UserId")?.Value;

        if (int.TryParse(userIdString, out int userId))
        {
            // Llamamos a tu servicio para actualizar en BD[cite: 11]
            await EventService.UpdateEventAsync(EventModel, userId);
            
            // Regresamos a la lista después de guardar
            Navigation.NavigateTo("/my-events");
        }
    }
}