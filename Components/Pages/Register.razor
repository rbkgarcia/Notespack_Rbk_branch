@page "/register"
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@inject NOTESPACK.Services.AuthService AuthService
@inject NavigationManager NavigationManager

<div class="login-container">
    <div class="glass-card">
        <h2>Create Account</h2>
        <p class="text-dim">Join the NOTESPACK community to manage your events.</p>
        
        @if (!string.IsNullOrEmpty(Message))
        {
            <div style="color: @(IsError ? "#ff5c5c" : "#2ec4b6"); background: @(IsError ? "rgba(255,75,75,0.1)" : "rgba(46,196,182,0.1)"); padding: 10px; border-radius: 8px; margin-bottom: 15px; font-size: 14px; text-align: center;">
                @Message
            </div>
        }

        <EditForm Model="RegisterModel" OnValidSubmit="HandleRegister" FormName="RegisterForm">
            <DataAnnotationsValidator />
            <AntiforgeryToken />

            <div class="form-group">
                <label>Email Address</label>
                <InputText @bind-Value="RegisterModel.Email" class="glass-input" placeholder="student@university.edu" />
                <ValidationMessage For="@(() => RegisterModel.Email)" />
            </div>
            
            <div class="form-group" style="margin-top: 15px; position: relative;">
                <label>Password</label>
                <div style="position: relative;">
                    <InputText type="@(showPassword ? "text" : "password")" @bind-Value="RegisterModel.Password" class="glass-input" placeholder="••••••••" />
                    <button type="button" @onclick="TogglePassword" @onclick:preventDefault="true" style="position: absolute; right: 10px; top: 10px; background: none; border: none; cursor: pointer; font-size: 12px; color: var(--accent);">
                        @(showPassword ? "Hide" : "Show")
                    </button>
                </div>
                <ValidationMessage For="@(() => RegisterModel.Password)" />
            </div>

            <div class="form-group" style="margin-top: 15px;">
                <label>Confirm Password</label>
                <InputText type="password" @bind-Value="RegisterModel.ConfirmPassword" class="glass-input" placeholder="••••••••" />
                <ValidationMessage For="@(() => RegisterModel.ConfirmPassword)" />
            </div>
            
            <button type="submit" class="btn-pill btn-primary-pill" style="width: 100%; margin-top: 20px;">
                Register
            </button>
        </EditForm>

        <div class="mt-3 text-center" style="margin-top: 20px; font-size: 14px;">
            Already have an account? <a href="/login" style="color: var(--accent);">Login here</a>
        </div>
    </div>
</div>

@code 
{
    private RegisterInput RegisterModel = new();
    private string Message = string.Empty;
    private bool IsError = false;
    private bool showPassword = false;

    private void TogglePassword() => showPassword = !showPassword;

    private async Task HandleRegister()
    {
        Message = string.Empty;
        IsError = false;

        bool registroExitoso = await AuthService.RegisterAsync(RegisterModel.Email, RegisterModel.Password);

        if (registroExitoso)
        {
            Message = "Registration successful! Redirecting to login...";
            await Task.Delay(2000); 
            NavigationManager.NavigateTo("/login");
        }
        else
        {
            Message = "This email is already registered.";
            IsError = true;
        }
    }

    public class RegisterInput
    {
        [Required, EmailAddress]
        public string Email { get; set; } = "";
        [Required, MinLength(6)]
        public string Password { get; set; } = "";
        [Required, Compare("Password")]
        public string ConfirmPassword { get; set; } = "";
    }
}