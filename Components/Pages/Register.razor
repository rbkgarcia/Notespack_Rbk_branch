@page "/register"
@rendermode InteractiveServer
@inject NOTESPACK.Services.AuthService AuthService
@inject NavigationManager NavigationManager

<PageTitle>Register · NOTESPACK</PageTitle>

<div class="login-container">
    <div class="glass-card">
        <h2>Create Account</h2>
        <p class="text-dim">Join the NOTESPACK community to manage your events.</p>
        
        @if (!string.IsNullOrEmpty(Message))
        {
            <div style="color: @(IsError ? "#ff5c5c" : "#2ec4b6"); background: @(IsError ? "rgba(255,75,75,0.1)" : "rgba(46,196,182,0.1)"); padding: 10px; border-radius: 8px; margin-bottom: 15px; font-size: 14px; text-align: center; border: 1px solid @(IsError ? "rgba(255,75,75,0.2)" : "rgba(46,196,182,0.2)");">
                @Message
            </div>
        }

        <form @onsubmit="HandleRegister" method="post">
    </form>

<EditForm Model="RegisterModel" OnValidSubmit="HandleRegister" FormName="RegisterForm">
    <AntiforgeryToken /> <div class="form-group">
        <label for="email">Email Address</label>
        <InputText id="email" class="glass-input" @bind-Value="RegisterModel.Email" required />
    </div>
    
    <div class="form-group" style="margin-top: 15px;">
        <label for="password">Password</label>
        <InputText type="password" id="password" class="glass-input" @bind-Value="RegisterModel.Password" required />
    </div>

    <div class="form-group" style="margin-top: 15px;">
        <label for="confirmPassword">Confirm Password</label>
        <InputText type="password" id="confirmPassword" class="glass-input" @bind-Value="RegisterModel.ConfirmPassword" required />
    </div>
    
    <button type="submit" class="btn-pill btn-primary-pill" style="width: 100%; margin-top: 20px;">
        Register
    </button>
</EditForm>
    </div>
</div>

@code {
    private RegisterInput RegisterModel { get; set; } = new();
    private string Message { get; set; } = string.Empty;
    private bool IsError { get; set; } = false;

    private async Task HandleRegister()
    {
        Message = string.Empty;
        IsError = false;

        if (RegisterModel.Password != RegisterModel.ConfirmPassword)
        {
            Message = "Passwords do not match.";
            IsError = true;
            return;
        }

        bool registroExitoso = await AuthService.RegisterAsync(RegisterModel.Email, RegisterModel.Password);

        if (registroExitoso)
        {
            Message = "Registration successful! Redirecting to login...";
            await Task.Delay(2000); 
            NavigationManager.NavigateTo("/login");
        }
        else
        {
            Message = "This email is already registered.";
            IsError = true;
        }
    }

    public class RegisterInput
    {
        public string Email { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}