@page "/event/details/{EventId:int}"
@using NOTESPACK.Models
@using NOTESPACK.Data
@using Microsoft.EntityFrameworkCore
@rendermode InteractiveServer
@inject EventContext Context
@inject NavigationManager Navigation

<div class="delete-event-page">
    <div class="cursor-glow" id="cursorGlow"></div>

    <div class="main-container">
        <div class="page-header">
            @if (Navigation.Uri.Contains("delete"))
            {
                <h1>Delete Event</h1>
            }
            else
            {
                <h1>Event Details</h1>
            }
        </div>

        <div class="glass-card form-container tilt-card">
            @if (EventModel == null)
            {
                <p class="text-white-50">Loading event data or event not found...</p>
            }
            else
            {
                <div class="event-preview-details text-white mb-4">
                    <div class="mb-3">
                        <strong class="text-white-50">Title:</strong> 
                        <span class="fs-5 ms-2 d-block mt-1 fw-bold text-white">@EventModel.Title</span>
                    </div>
                    <div class="mb-3">
                        <strong class="text-white-50">Description:</strong> 
                        <span class="ms-2 d-block mt-1 text-white-50">@EventModel.Description</span>
                    </div>
                    <div class="mb-3">
                        <strong class="text-white-50">Date:</strong> 
                        <span class="ms-2 d-block mt-1 text-white">@EventModel.Date.ToShortDateString()</span>
                    </div>
                    <div class="mb-3">
                        <strong class="text-white-50">Location:</strong> 
                        <span class="ms-2 d-block mt-1 text-white">@EventModel.Location</span>
                    </div>
                </div>

                <div class="form-actions mt-4">
                        <NavLink href="@($"event/edit/{EventModel.Id}")" class="btn-submit text-decoration-none text-center bg-warning border-0">
                            Edit Event
                        </NavLink>
                    <NavLink href="my-events" class="btn-cancel text-decoration-none text-center">
                        Back to List
                    </NavLink>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public int EventId { get; set; }
    private Event? EventModel { get; set; }

    protected override async Task OnInitializedAsync()
    {
        EventModel = await Context.Events.FirstOrDefaultAsync(e => e.Id == EventId);
    }
}